\usepackage{titlesec}

% 针对 section 的设置
\titleformat{\section}
  {\bfseries\LARGE\centering}              % 标题的通用属性（如加粗、字号）
  {\fontspec{Times New Roman}\thesection} % 编号：强制调用 Times New Roman
  {0.5em}                          % 编号和文字之间的距离
  {\heiti}                    % 标题文字：调用黑体 (因为你前面设置了 \setCJKsansfont{SimHei})

% 针对 chapter 的设置
\titleformat{\chapter}
  {\heiti\bfseries\huge\centering} % 1. 全局调用黑体、加粗、\huge(加大)、\centering(居中)
  {第\zhnum{chapter}章}             % 2. 编号直接改用汉字数字，去掉了英文数字的Times字体
  {0.5em}                            % 3. 编号和文字之间的距离
  {}                               % 4. 留空，因为前面第一步已经全局指定了 \heiti




