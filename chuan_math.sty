% 3. 颜色主题定义 (极简学术风)
% ==========================================
\colorlet{ThemeBlue}{Cyan!8}       % 淡蓝色 (用于定理、命题)
\colorlet{ThemeRed}{WildStrawberry!8} % 水红色 (用于定义、重要结论)
\colorlet{ThemeGray}{black!5}      % 浅灰色 (用于例题)

% ==========================================
% 4. 大学数学笔记环境 (定理、定义、命题等)
% ==========================================
% 定义定理样式
\declaretheoremstyle[
    headfont=\bfseries,
    bodyfont=\normalfont,
    headpunct={\ },
    mdframed={
        backgroundcolor=ThemeBlue,
        linecolor=Cyan!30,
        linewidth=1pt,
        topline=false, rightline=false, bottomline=false, % 只留左边框，极简风
        innertopmargin=6pt, innerbottommargin=6pt
    }
]{thmblue}
 
\declaretheoremstyle[
    headfont=\bfseries,
    bodyfont=\normalfont,
    headpunct={\ },
    mdframed={
        backgroundcolor=ThemeRed,
        linecolor=WildStrawberry!40,
        linewidth=1pt,
        topline=false, rightline=false, bottomline=false,
        innertopmargin=6pt, innerbottommargin=6pt
    }
]{thmred}

% 绑定具体环境
\declaretheorem[style=thmblue, name={\heiti 定理}, numberwithin=section]{theorem}
\declaretheorem[style=thmblue, name={\heiti 命题}, numberlike=theorem]{proposition}
\declaretheorem[style=thmblue, name={\heiti 推论}, numberlike=theorem]{corollary}

\declaretheorem[style=thmred, name={\heiti 定义}, numberwithin=section]{definition}

% 例题环境 (不用色块，用简单的灰色左边框区分)
\declaretheoremstyle[
    headfont=\bfseries,
    bodyfont=\normalfont,
    headpunct={\ },
    mdframed={
        backgroundcolor=ThemeGray,
        linecolor=black!20,
        linewidth=2pt,
        topline=false, rightline=false, bottomline=false,
        innertopmargin=6pt, innerbottommargin=6pt
    }
]{thmgray}
\declaretheorem[style=thmgray, name={\heiti 例题}, numberwithin=section]{example}

% 定义一个左侧带灰色粗线的环境
\newtcolorbox{notebox}{
    blanker, 
    borderline west={3pt}{0pt}{gray!50}, 
    left=10pt, 
    top=4pt, 
    bottom=4pt
}

% 1. 定义深紫色
\definecolor{proofpurple}{HTML}{4A148C} 

% 2. 重新定义 proof 环境（极弱底色 + 紫色首尾 + 黑色楷体正文）
\makeatletter
\renewenvironment{proof}[1][证明]{
    \begin{tcolorbox}[
        enhanced,      % 开启高级外观控制
        breakable,     % 允许跨页
        frame hidden,  % 隐藏四周的边框线
        colback=proofpurple!3, % 极其微弱的底色：3% 的深紫色混合 97% 的白色
        sharp corners, % 直角边缘，更具学术感
        boxsep=0pt,
        left=10pt, right=10pt, top=8pt, bottom=8pt, % 框内留白
        before skip=12pt, after skip=12pt % 框外上下间距
    ]
    % 标题部分：深紫色 + 黑体
    \noindent\textcolor{proofpurple}{\heiti #1：}\ignorespaces
    % 正文部分：开启楷体（默认黑色）
    \kaishu
}{
    % 结尾部分：靠右的深紫色实心方块
    \hfill\textcolor{proofpurple}{$\blacksquare$}
    \end{tcolorbox}
}
\makeatother

\newcommand{\sepline}{
    \par\vspace{1em} % 线上方的间距
    \noindent\textcolor{gray!40}{\rule{\textwidth}{0.5pt}} % 40%浓度的灰色细线
    \par\vspace{1em} % 线下方的间距
}

\newcommand{\summary}[1]{{\kaishu \textcolor{cyan}{#1}}}
% ==========================================
% 5. 高中题库专用环境 (题目、开关、选择题)
% ==========================================
% 答案显示开关：想生成不带答案的试卷，就把下面这行改成 \showanswerfalse
% \newif\ifshowanswer
% \showanswertrue  

\newcommand{\setdisplay}[1]{\def\displaymode{#1}}
\setdisplay{2} % 模板默认全局开启完整版

\newcounter{exercise}[section]
\newenvironment{exe}[1][]{%
    \nopagebreak\par\noindent
    \refstepcounter{exercise}%
    {\bfseries \theexercise .}%
    % 当模式为 1 或 2 时，显示蓝色的标签
    \ifnum\displaymode>0 
        \setbox0=\hbox{#1}\ifdim\wd0>0pt 
            \hspace{0.3em}{\footnotesize\color{Plum}\textbf{[#1]}}%
        \fi
    \fi
    \hspace{0.5em}\ignorespaces
}{%
    \par
}

% 答案/解析环境
\NewEnviron{sol}{
    \ifnum\displaymode>0
        \nopagebreak
        % 把 \begin{small} 换成大括号包裹的 {\small ... \par}
        {\small
            \noindent\textbf{\textcolor{NavyBlue}{【解析】}}\ \BODY\par
        }
        \vspace{0.8em}
    %\else
    \fi
}

\NewEnviron{note}{
    \ifnum\displaymode>1
        \nopagebreak
        {\small
            % 使用松石绿/墨绿色，与解析的蓝色拉开视觉反差
            \noindent\textbf{\textcolor{PineGreen}{【备注】}}\ \BODY\par
        }
        \vspace{0.8em}
    \fi
}

