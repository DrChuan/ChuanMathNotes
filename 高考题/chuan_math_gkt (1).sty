% 高考试卷符号修正：平行符号用高中印刷中常见的左倾双斜线，避免显示成两条竖杠. 
\DeclareRobustCommand{\gktparallel}{\mathrel{\backslash\mkern-5.8mu\backslash}}
\AtBeginDocument{\let\gktoldparallel\parallel\let\parallel\gktparallel}

% 圈号数字修正：若字体缺少 ①②③④ 等字符，则用 TikZ 绘制，避免显示成方框. 
\DeclareRobustCommand{\gktcircled}[1]{%
  \ifmmode
    \text{\gktcircledtext{#1}}%
  \else
    \gktcircledtext{#1}%
  \fi
}
\newcommand{\gktcircledtext}[1]{%
  \tikz[baseline=(gktcirclednode.base)]{%
    \node[draw,circle,inner sep=0pt,minimum size=1.25em,line width=0.42pt,
      font=\fontsize{8pt}{8pt}\selectfont] (gktcirclednode) {#1};%
  }%
}
\newunicodechar{①}{\gktcircled{1}}
\newunicodechar{②}{\gktcircled{2}}
\newunicodechar{③}{\gktcircled{3}}
\newunicodechar{④}{\gktcircled{4}}
\newunicodechar{⑤}{\gktcircled{5}}
\newunicodechar{⑥}{\gktcircled{6}}
\newunicodechar{⑦}{\gktcircled{7}}
\newunicodechar{⑧}{\gktcircled{8}}
\newunicodechar{⑨}{\gktcircled{9}}
\newunicodechar{⑩}{\gktcircled{10}}
\newunicodechar{⑪}{\gktcircled{11}}
\newunicodechar{⑫}{\gktcircled{12}}
\newunicodechar{⑬}{\gktcircled{13}}
\newunicodechar{⑭}{\gktcircled{14}}
\newunicodechar{⑮}{\gktcircled{15}}
\newunicodechar{⑯}{\gktcircled{16}}
\newunicodechar{⑰}{\gktcircled{17}}
\newunicodechar{⑱}{\gktcircled{18}}
\newunicodechar{⑲}{\gktcircled{19}}
\newunicodechar{⑳}{\gktcircled{20}}


