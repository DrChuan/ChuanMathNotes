% ==========================================
% 5. 高中题库专用环境
% ==========================================

\newcommand{\setdisplay}[1]{\def\displaymode{#1}}
\setdisplay{2}

\newcounter{exercise}[section]
\newenvironment{exe}[1][]{%
    \nopagebreak\par\noindent
    \refstepcounter{exercise}%
    {\bfseries \theexercise .}%
    \ifnum\displaymode>0
        \setbox0=\hbox{#1}\ifdim\wd0>0pt
            \hspace{0.3em}{\footnotesize\color{Plum}\textbf{[#1]}}%
        \fi
    \fi
    \hspace{0.5em}\ignorespaces
}{%
    \par
}

\NewEnviron{sol}{
    \ifnum\displaymode>0
        \nopagebreak
        {\small
            \noindent\textbf{\textcolor{NavyBlue}{【解析】}}\ \BODY\par
        }
        \vspace{0.8em}
    \fi
}

\NewEnviron{note}{
    \ifnum\displaymode>1
        \nopagebreak
        {\small
            \noindent\textbf{\textcolor{PineGreen}{【备注】}}\ \BODY\par
        }
        \vspace{0.8em}
    \fi
}

\settasks{
    label=\Alph*．︀,
    label-width=1.5em,
    item-indent=3.5em,
    column-sep=1em,
    after-item-skip=-0.2em,
    before-skip=-0.9em
}

